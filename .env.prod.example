# ─────────────────────────────────────────────────────────────────────────────
# Template de produção. Copie para `.env.prod` (NÃO commitado) e preencha.
# Usado por docker/docker-compose.prod.yml nos serviços `web` (Django) e `db`
# (Postgres). Ver docs/technical/go-live-checklist.md.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ───────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
# Gere uma chave forte (>=50 chars). Ex.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=__TROQUE_POR_UMA_CHAVE_FORTE__
DEBUG=False
# Domínio(s) reais, separados por vírgula (sem esquema). Ex.: portal.minhaescola.com.br
ALLOWED_HOSTS=komuniki.com.br,www.komuniki.com.br,kellyfarias.com.br,www.kellyfarias.com.br,2.25.178.16,localhost,127.0.0.1
# Origens confiáveis para CSRF — COM esquema https. Ex.: https://seu-dominio.com.br
CSRF_TRUSTED_ORIGINS=https://komuniki.com.br,https://www.komuniki.com.br,https://kellyfarias.com.br,https://www.kellyfarias.com.br
# Redirect HTTP->HTTPS no Django (mantenha True quando o TLS estiver ativo).
SECURE_SSL_REDIRECT=True

# ── Banco de dados (Postgres) ────────────────────────────────────────────────
# O serviço `db` inicializa com POSTGRES_*; o Django/healthcheck usam DB_*.
# Os valores DEVEM coincidir entre os dois blocos.
POSTGRES_DB=news_portal
POSTGRES_USER=news_portal_user
POSTGRES_PASSWORD=__TROQUE_POR_UMA_SENHA_FORTE__
DB_NAME=news_portal
DB_USER=news_portal_user
DB_PASSWORD=__TROQUE_POR_UMA_SENHA_FORTE__
# Dentro do compose, o host é o NOME DO SERVIÇO `db` (não localhost).
DB_HOST=db
DB_PORT=5432

# ── E-mail (SMTP real para newsletter/contato) ───────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.seuprovedor.com
EMAIL_PORT=587
EMAIL_HOST_USER=usuario@seu-dominio.com.br
EMAIL_HOST_PASSWORD=__SENHA_SMTP__
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=News Portal <noticias@seu-dominio.com.br>

# ── Cloudflare Turnstile (verificação anti-bot dos formulários) ──────────────
# OBRIGATÓRIO em produção. Sem estas chaves e com DEBUG=False, verify_turnstile()
# recusa todo envio — contato, newsletter e comentários falham-fechado para o
# usuário real (ver apps/common/turnstile.py). Crie um widget em
# https://dash.cloudflare.com → Turnstile e registre os 4 hostnames
# (komuniki.com.br, www.komuniki.com.br, kellyfarias.com.br, www.kellyfarias.com.br).
CLOUDFLARE_TURNSTILE_SITE_KEY=__SITE_KEY_DO_PAINEL_CLOUDFLARE__
CLOUDFLARE_TURNSTILE_SECRET_KEY=__SECRET_KEY_DO_PAINEL_CLOUDFLARE__
# Timeout (segundos) da chamada ao siteverify do Cloudflare.
CLOUDFLARE_TURNSTILE_VERIFY_TIMEOUT=5.0

# ── Observabilidade (opcional) ───────────────────────────────────────────────
# Deixe SENTRY_DSN vazio para desativar o Sentry. Preencha para habilitar.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO

# ── Identidade do Site (go-live) ─────────────────────────────────────────────
# Usado por `python manage.py set_site_domain` para corrigir o domínio do Site
# (o seed inicial usa example.com, o que quebra links de e-mail). Ver checklist.
SITE_DOMAIN=komuniki.com.br
SITE_NAME=Komuniki

# URLs publicas dos dois portais. Usadas para links entre dominios, ja que o
# mesmo Django serve Komuniki e Blog da Kelly.
KOMUNIKI_PUBLIC_URL=https://komuniki.com.br
KELLY_BLOG_PUBLIC_URL=https://kellyfarias.com.br/news
